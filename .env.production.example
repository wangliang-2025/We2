# ====== 生产环境配置 ======
# 把这个文件复制成 .env，填好后 docker compose 才能正确启动

# === 必填：域名 + HTTPS 证书邮箱 ===
DOMAIN=love.example.com
ACME_EMAIL=you@example.com

# === 必填：JWT 签名密钥（必须 >=32 字符随机字符串）===
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=please_generate_a_long_random_string_at_least_32_chars_replace_me

# === 可选：AI 接入（不填则使用本地情话模板）===
# 支持的 provider:
#   openai      OpenAI 官方 (需要科学上网或代理)
#   deepseek    深度求索 (国内便宜，对话强)
#   zhipu       智谱 ChatGLM
#   kimi        月之暗面 Moonshot
#   qwen        阿里通义千问
#   custom      其他 OpenAI 兼容协议
#
# 推荐国内：deepseek（每月 10-20 元很够用）或 qwen（有免费额度）
AI_PROVIDER=
AI_API_KEY=
# 下面两个可选，留空使用 provider 默认值
AI_BASE_URL=
AI_MODEL=
